# Copy to .env and adjust as needed. All values shown are the defaults.

DEBUG=true

MAX_PAGES_PER_PDF=5000
MIN_TEXT_CHARS_FOR_VALID_PAGE=30

DEFAULT_LANGUAGE=fa

OCR_ENABLED=true
OCR_LANGUAGE=fas+eng
OCR_RENDER_RESOLUTION=200
OCR_TESSERACT_PSM=6
OCR_PREPROCESSING_MODE=autocontrast
# OCR_THRESHOLD=
OCR_LOW_CONFIDENCE_THRESHOLD=45

# Concept extraction (Knowledge Graph roadmap — see ADR-002). Every other
# feature works without this set at all; leave it commented out until
# you're ready to use --extract-concepts / extract_concepts=true.
# ANTHROPIC_API_KEY=sk-ant-...
CONCEPT_EXTRACTION_MODEL=claude-sonnet-5
CONCEPT_EXTRACTION_MAX_TOKENS=4096

# Telegram interface (token/API credentials must only be supplied at runtime)
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_API_BASE_URL=http://127.0.0.1:8081/bot
TELEGRAM_BOT_API_FILE_URL=http://127.0.0.1:8081/file/bot
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_ALLOW_ALL_DEVELOPMENT=false
TELEGRAM_LOCAL_MODE=true
TELEGRAM_MAX_FILE_SIZE_MB=1900
TELEGRAM_PROCESSING_CONCURRENCY=1
TELEGRAM_JOB_QUEUE_SIZE=10
TELEGRAM_INPUT_DIR=input/telegram
TELEGRAM_WORK_DIR=workspaces/telegram
TELEGRAM_OUTPUT_RETENTION_HOURS=24
TELEGRAM_STATUS_UPDATE_INTERVAL_SECONDS=5
TELEGRAM_MIN_FREE_DISK_SPACE_MB=1024
TELEGRAM_PROCESSING_TIMEOUT_SECONDS=7200
