# Copy to .env and adjust as needed. All values shown are the defaults.

DEBUG=true

MAX_PAGES_PER_PDF=5000
MIN_TEXT_CHARS_FOR_VALID_PAGE=30

DEFAULT_LANGUAGE=fa

OCR_ENABLED=true
OCR_LANGUAGE=fas
OCR_RENDER_RESOLUTION=200

# Concept extraction (Knowledge Graph roadmap — see ADR-002). Every other
# feature works without this set at all; leave it commented out until
# you're ready to use --extract-concepts / extract_concepts=true.
# ANTHROPIC_API_KEY=sk-ant-...
CONCEPT_EXTRACTION_MODEL=claude-sonnet-5
CONCEPT_EXTRACTION_MAX_TOKENS=4096
