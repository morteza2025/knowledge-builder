__pycache__/
*.pyc
.pytest_cache/

.env

logs/*.log

# Generated outputs — reproducible from input/ + code, don't need to be
# committed. Remove this if you'd rather track outputs for review/diffing.
outputs/json/*
outputs/markdown/*
outputs/django_seed/*
outputs/knowledge_graph/*
!outputs/json/.gitkeep
!outputs/markdown/.gitkeep
!outputs/django_seed/.gitkeep
!outputs/knowledge_graph/.gitkeep

# Large source PDFs don't belong in git history. Keep them in input/ locally
# or fetch from Drive at run time; commit only the small sample used by tests.
input/*
!input/C110220.pdf
!input/.gitkeep

.vscode/
.idea/
*.egg-info/

# Telegram runtime state and Local Bot API data
input/telegram/
workspaces/
telegram-bot-api-data/
*.part
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal
*.telegram.zip
